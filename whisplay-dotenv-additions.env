# ─────────────────────────────────────────────
# OpenClaw / Whisplay IM Bridge Configuration
# Add these lines to your ~/whisplay-ai-chatbot/.env file
# ─────────────────────────────────────────────

# Switch LLM backend to IM mode (routes all voice input to OpenClaw)
LLM_SERVER=whisplay-im

# Bridge server settings (defaults shown — only override if needed)
# WHISPLAY_IM_BRIDGE_HOST=127.0.0.1
# WHISPLAY_IM_BRIDGE_PORT=18888
# WHISPLAY_IM_INBOX_PATH=/whisplay-im/inbox
# WHISPLAY_IM_POLL_PATH=/whisplay-im/poll
# WHISPLAY_IM_SEND_PATH=/whisplay-im/send

# REQUIRED: Set this token and use the same value in openclaw.json
WHISPLAY_IM_TOKEN=YOUR_SHARED_SECRET_TOKEN

# Timeout for waiting on OpenClaw replies (milliseconds)
# WHISPLAY_IM_TIMEOUT_MS=30000
